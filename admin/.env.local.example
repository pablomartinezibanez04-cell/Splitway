# admin/.env.local.example
# Copy to .env.local and fill in. Never commit .env.local.
#
# Get these values from your Supabase project dashboard:
#   Settings → API → Project URL                   → NEXT_PUBLIC_SUPABASE_URL
#   Settings → API → Project API keys → anon       → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   Settings → API → Project API keys → service_role → SUPABASE_SERVICE_ROLE_KEY

# Public — safe in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — server-only. Reads via this key bypass RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
