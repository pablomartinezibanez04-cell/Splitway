# admin/.env.local.example
# Copy to .env.local and fill in. Never commit .env.local.
#
# Get these values from your Supabase project dashboard:
#   Settings → API → Project URL                   → NEXT_PUBLIC_SUPABASE_URL
#   Settings → API → Project API keys → anon       → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   Settings → API → Project API keys → service_role → SUPABASE_SERVICE_ROLE_KEY
#
# Docker:
#   Dev:  docker compose up
#   Prod: docker build \
#           --build-arg NEXT_PUBLIC_SUPABASE_URL=... \
#           --build-arg NEXT_PUBLIC_SUPABASE_ANON_KEY=... \
#           -t splitway-admin .
#         docker run -p 3000:3000 --env-file .env.local splitway-admin

# Public — safe in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — server-only. Reads via this key bypass RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Public — safe in the browser. Used by the /routes/[id] map preview.
# Get a token from https://account.mapbox.com/ → "Default public token"
# or create a new one scoped to "styles:read" + "fonts:read" + "tiles:read".
NEXT_PUBLIC_MAPBOX_TOKEN=

# Server-only. Comma-separated allowlist of hosts the OAuth callback may
# redirect back to. STRONGLY recommended in production: it closes a
# post-login open-redirect via spoofed X-Forwarded-Host. Leave empty in
# local dev. Example: admin.splitway.app,splitway.app
ADMIN_ALLOWED_REDIRECT_HOSTS=
